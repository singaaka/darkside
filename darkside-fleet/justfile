# darkside-fleet task runner. Install just with `brew install just`.
# Run `just` (no args) to see this list.

# Default: list recipes.
default:
    @just --list

# Generate Go + TS bindings from .proto sources.
proto:
    go tool github.com/bufbuild/buf/cmd/buf generate

# Generate the typed sqlite query layer.
sqlc:
    go tool github.com/sqlc-dev/sqlc/cmd/sqlc generate

# Create a new versioned migration. Pass a snake_case name.
new-migration name:
    go tool github.com/pressly/goose/v3/cmd/goose -dir internal/db/migrations create {{name}} sql

# Tidy Go module deps.
tidy:
    go mod tidy

# Run darkside-fleet locally (starts web UI on :7373 by default).
dev:
    go run ./cmd/darkside-fleet

# Build a standalone Go binary with the frontend embedded.
build:
    cd frontend && pnpm run build
    rm -rf internal/frontend/dist
    cp -r frontend/dist internal/frontend/dist
    go build -o bin/darkside-fleet ./cmd/darkside-fleet

# Wipe generated artifacts.
clean:
    rm -rf internal/frontend/dist frontend/dist frontend/node_modules bin/

# Vet
vet:
    go vet
