# Copy to .env. All three vars are consumed by docker-compose.yml.

# Hostname darkside is reachable at, e.g. darkside.hotelstack.co.
# Used in the traefik Host() rule. Must resolve to the host running compose.
DARKSIDE_HOST=darkside.example.com

# Email Let's Encrypt sends cert-expiry notifications to.
ACME_EMAIL=you@example.com

# Basic-auth credentials for the dashboard, in htpasswd format. Generate with:
#   htpasswd -nbB admin yourpassword
# Then escape every `$` as `$$` (compose treats `$` as a variable prefix).
DARKSIDE_BASIC_AUTH=admin:$$2y$$05$$KqJgxbZX1qbW1V8FwVKZ8eXl5Q5VYfZ6oWf9NwYxsXzXyR2xJYJYi
